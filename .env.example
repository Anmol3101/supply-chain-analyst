# Supply Chain Network Analyst - Environment Configuration

# PostgreSQL Database URL (Required)
# Example: postgresql://user:password@localhost:5432/analyst_db
# For Supabase: postgresql://postgres:[password]@[subdomain].supabase.co:5432/postgres
DATABASE_URL=

# Claude API Key (Required for LLM fallback scenarios)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: Vercel Environment
VERCEL_ENV=development
VERCEL_URL=localhost:3000

# Optional: API Rate Limiting
API_RATE_LIMIT_REQUESTS_PER_MINUTE=100

# Optional: Logging
LOG_LEVEL=info
